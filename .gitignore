# Terraform working directory
.terraform/
**/.terraform/*

# Terraform state files (VERY IMPORTANT to ignore)
*.tfstate
*.tfstate.*
terraform.tfstate
terraform.tfstate.backup

# Terraform lock file (optional: ignore or keep)
.terraform.lock.hcl

# Crash logs
crash.log

# Sensitive variable files
*.tfvars
*.tfvars.json

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI config files
.terraformrc
terraform.rc

# System files
.DS_Store
Thumbs.db

# Logs
*.log

# Ignore large binaries (safety)
*.exe
*.zip
*.tar
*.gz

.terraform/
*.tfstate
*.tfstate.*
.terraform.lock.hcl